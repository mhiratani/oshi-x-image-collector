# ===== 必須 =====
# X API v2 の Bearer Token（https://developer.x.com/ で取得）
X_BEARER_TOKEN=

PG_HOST=your.db.ip.address
PG_PORT=5435
PG_USER=pg_user
PG_PASSWORD=pg_password
PG_DB=pg_db_name

# OIDCログイン管理画面でクライアントを登録し、
# リダイレクトURIを <AUTH_URLの起点>/api/auth/callback/pocketid にする
AUTH_SECRET=
AUTH_URL=https://x-image-collector.example.com
OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Cloudflare R2（画像バックアップの保存先）
# バケットの「API トークンを管理」から Object Read & Write 権限で発行する
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCOUNT_ACCESS_KEY_ID=
CLOUDFLARE_ACCOUNT_API_SECRET=
CLOUDFLARE_ACCOUNT_ENDPOINT=
# CLOUDFLARE_ACCOUNT_API_TOKEN はアプリ実行時には未使用（wrangler CLI等の運用作業用）