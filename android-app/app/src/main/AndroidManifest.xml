<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Android 11+ のパッケージ可視性対策。X(旧Twitter)公式アプリを名指しで起動できるよう、
        twitter:// スキームと https(App Link)、およびパッケージ本体を <queries> に宣言する。
        これが無いと resolveActivity/setPackage が X アプリを見つけられず、
        「Xで開く」がブラウザへ落ちてしまう。
    -->
    <queries>
        <package android:name="com.twitter.android" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="twitter" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OshiXImageCollector">

        <!--
            ML Kit: インストール時に顔検出モデルをPlay Services側へ事前ダウンロードさせる。
            モデル未取得の間はFaceDetectorがUnavailableを返し、is_faceは未判定のまま
            次回の「最新を取得」時に再試行される。
        -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="face" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.OshiXImageCollector">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
